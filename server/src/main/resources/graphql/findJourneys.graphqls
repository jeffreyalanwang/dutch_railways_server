extend type Query {
    findJourneys(
        originStation: ID!,
        destinationStation: ID!,
        earliestDepartTime: DateTime!,
        latestArriveTime: DateTime = null,
        maxCount: Int = null,
    ): [Journey]
}

type Journey {
    points: [JourneyPoint!]!
}

type JourneyPoint {
    time: DateTime!,
    place: Station!,
    via: PassService,
}